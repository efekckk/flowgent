# Flowgent — copy to .env and edit before `make demo` / `docker compose up`.
# Anything not commented out is required by cmd/flowgent at boot.

# Database. docker-compose.yml points this at the postgres service.
DATABASE_URL=postgres://flowgent:flowgent@postgres:5432/flowgent?sslmode=disable

# AES-256-GCM master key for the credential store. Generate with:
#   openssl rand -base64 32
# The server will refuse to boot if this is missing or wrong-length.
FLOWGENT_CRED_KEY=

# Public base URL the SPA hands out in webhook URLs. For docker compose
# on a laptop this is the host's URL.
FLOWGENT_PUBLIC_BASE_URL=http://localhost:8080

# AI provider keys. At least one is needed for the chat agent to work;
# the rest of the app boots without them.
FLOWGENT_OPENAI_KEY=
FLOWGENT_ANTHROPIC_KEY=
FLOWGENT_DEFAULT_PROVIDER=openai

# Optional. Defaults shown.
# LOG_LEVEL=info
# PORT=8080
# SESSION_COOKIE_DOMAIN=localhost
# SESSION_COOKIE_SECURE=false
