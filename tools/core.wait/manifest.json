{
  "slug": "core.wait",
  "version": "1.0.0",
  "display_name": "Wait",
  "category": "control",
  "description": "Pauses workflow execution for the given number of milliseconds. Useful for rate-limiting downstream calls or scheduling a delayed action.",
  "inputs": {
    "type": "object",
    "required": ["ms"],
    "properties": {
      "ms": { "type": "integer", "minimum": 0, "maximum": 60000, "description": "Milliseconds to wait." }
    }
  },
  "outputs": {
    "type": "object",
    "properties": {
      "waited_ms": { "type": "integer" }
    }
  }
}
